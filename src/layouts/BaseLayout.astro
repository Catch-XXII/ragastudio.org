---
import BaseHead from "../components/BaseHead.astro";
import Footer from "../components/Footer.astro";
import Sidebar from "../components/Sidebar.astro";
import TopNav from "../components/TopNav.astro";
import BackToTop from "../components/BackToTop.astro";
import Analytics from "@vercel/analytics/astro";
import SpeedInsights from "@vercel/speed-insights/astro";
import "../styles/global.css";

interface Props {
  title: string;
  description: string;
  image?: string;
  favicon?: string;
}

const { title, description, image, favicon } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={title} description={description} image={image} favicon={favicon} />
  </head>
  <body class="min-h-screen flex flex-col">
    <TopNav />
    <Sidebar />
    <div class="lg:pt-12 flex flex-col min-h-screen">
      <main class="flex-1 w-full max-w-[680px] mx-auto px-6 py-10 border-x border-[var(--color-accent)]/20">
        <slot />
      </main>
      <Footer />
    </div>
    <BackToTop />
    <Analytics />
    <SpeedInsights />
  </body>
</html>
