<button
  id="back-to-top"
  aria-label="Back to top"
  class="fixed bottom-6 right-6 z-50 w-10 h-10 rounded-full border border-[var(--color-border)] bg-[var(--color-bg)] text-[var(--color-text-faint)] hover:text-[var(--color-accent-soft)] hover:border-[var(--color-accent-soft)] transition-all duration-300 opacity-0 translate-y-4 pointer-events-none flex items-center justify-center cursor-pointer"
>
  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
    <path d="M18 15l-6-6-6 6"/>
  </svg>
</button>

<style>
  #back-to-top.visible {
    opacity: 1;
    translate: 0 0;
    pointer-events: auto;
    border-color: var(--color-accent-soft);
    color: var(--color-accent-soft);
  }
</style>

<script>
  const btn = document.getElementById('back-to-top');
  if (btn) {
    window.addEventListener('scroll', () => {
      btn.classList.toggle('visible', window.scrollY > 400);
    }, { passive: true });
    btn.addEventListener('click', () => {
      window.scrollTo({ top: 0, behavior: 'smooth' });
    });
  }
</script>
