---
interface Props {
  title: string;
  description: string;
  date: Date;
  tags: string[];
  readingTime?: string;
}

const { title, description, date, tags, readingTime } = Astro.props;

const formattedDate = date.toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
---

<a href={`/posts/${Astro.props.slug.replace(/\.mdx?$/, "")}`} class="block group">
  <article
    class="p-6 my-4 rounded-lg bg-[var(--color-accent)]/5 border border-[var(--color-accent)]/10 group-hover:bg-[var(--color-accent)]/10 transition-colors"
  >
    <div class="flex items-center gap-3">
      <time
        class="font-[family-name:var(--font-mono)] text-sm tracking-[1.5px] uppercase text-[var(--color-text-muted)]"
      >
        {formattedDate}
      </time>
      {readingTime && (
        <span class="font-[family-name:var(--font-mono)] text-sm tracking-[1px] text-[var(--color-text-faint)]">
          · {readingTime}
        </span>
      )}
    </div>
    <h3
      class="text-2xl font-medium mt-1 text-[var(--color-text-primary)] group-hover:text-[var(--color-accent-soft)] transition-colors"
    >
      {title}
    </h3>
    <p class="text-lg text-[var(--color-text-secondary)] mt-1 line-clamp-2">
      {description}
    </p>
    {
      tags.length > 0 && (
        <div class="flex gap-2 mt-2">
          {tags.map((tag) => (
            <span class="font-[family-name:var(--font-mono)] text-xs tracking-[1px] uppercase text-[var(--color-text-faint)] bg-[var(--color-surface)] px-2 py-0.5 rounded">
              {tag}
            </span>
          ))}
        </div>
      )
    }
  </article>
</a>
