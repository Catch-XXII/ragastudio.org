---
import BaseLayout from "../layouts/BaseLayout.astro";
import PostCard from "../components/PostCard.astro";
import Breadcrumbs from "../components/Breadcrumbs.astro";
import { getCollection } from "astro:content";
import { getReadingTime } from "../utils/reading-time";
import { getCategoryById } from "../config/categories";
import { getEmojiFavicon } from "../utils/favicon";

const allPosts = (await getCollection("posts", ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

// Build searchable index
const searchIndex = allPosts.map(post => {
  const categoryMeta = getCategoryById(post.data.category);
  return {
    id: post.id,
    title: post.data.title,
    description: post.data.description,
    tags: post.data.tags,
    category: post.data.category,
    categoryEmoji: categoryMeta?.emoji || '📄',
    date: post.data.date,
    content: post.body.substring(0, 500), // First 500 chars for preview
  };
});

const favicon = getEmojiFavicon('🔍');
---

<BaseLayout title="Search Articles" description="Search through all articles and blog posts" favicon={favicon}>
  <Breadcrumbs items={[{ label: "Search" }]} />
  
  <div class="mb-12">
    <h1 class="text-4xl font-semibold mb-6">Search Articles</h1>
    <div class="relative">
      <input
        id="search-input"
        type="text"
        placeholder="Search by title, tags, or content..."
        class="w-full px-6 py-4 text-lg bg-[var(--color-surface)] border border-[var(--color-border)] rounded-lg focus:outline-none focus:border-[var(--color-accent)] transition-colors"
        aria-label="Search articles"
        autofocus
      />
      <span class="absolute right-6 top-1/2 -translate-y-1/2 text-[var(--color-text-muted)]">🔍</span>
    </div>
  </div>

  <!-- Results container -->
  <div id="search-results">
    <p class="text-[var(--color-text-muted)] text-center py-8">Start typing to search articles...</p>
  </div>

  <!-- Hidden search index -->
  <script id="search-index" type="application/json" set:html={JSON.stringify(searchIndex)}>
  </script>

  <!-- Search logic -->
  <script>
    const searchInput = document.getElementById('search-input');
    const resultsContainer = document.getElementById('search-results');
    const searchIndexScript = document.getElementById('search-index');
    const searchIndex = JSON.parse(searchIndexScript.textContent);

    function performSearch(query) {
      if (!query.trim()) {
        resultsContainer.innerHTML = '<p class="text-[var(--color-text-muted)] text-center py-8">Start typing to search articles...</p>';
        return;
      }

      const lowerQuery = query.toLowerCase();
      
      // Filter posts that match the query
      const results = searchIndex.filter(post => {
        const titleMatch = post.title.toLowerCase().includes(lowerQuery);
        const descMatch = post.description.toLowerCase().includes(lowerQuery);
        const tagsMatch = post.tags.some(tag => tag.toLowerCase().includes(lowerQuery));
        const contentMatch = post.content.toLowerCase().includes(lowerQuery);
        return titleMatch || descMatch || tagsMatch || contentMatch;
      });

      // Sort by relevance: title matches first, then others
      results.sort((a, b) => {
        const aTitle = a.title.toLowerCase().includes(lowerQuery) ? 0 : 1;
        const bTitle = b.title.toLowerCase().includes(lowerQuery) ? 0 : 1;
        return aTitle - bTitle;
      });

      // Render results or "no results" message
      if (results.length === 0) {
        resultsContainer.innerHTML = `
          <div class="text-center py-12">
            <p class="text-[var(--color-text-muted)] mb-2">No articles found matching "${query}"</p>
            <p class="text-sm text-[var(--color-text-muted)]">Try different keywords or browse by category</p>
          </div>
        `;
        return;
      }

      // Build HTML for results
      const resultsHTML = results.map(post => {
        const date = new Date(post.date);
        const dateStr = date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
        const tagsHTML = post.tags.map(tag => `<a href="/tags/${tag}" class="text-xs text-[var(--color-text-muted)] hover:text-[var(--color-accent-soft)] transition-colors">#${tag}</a>`).join(' ');
        
        return `
          <article class="mb-6 pb-6 border-b border-[var(--color-border)] last:border-b-0">
            <h2 class="text-xl font-semibold mb-2 hover:text-[var(--color-accent-soft)] transition-colors">
              <span class="text-2xl mr-2">${post.categoryEmoji}</span>
              <a href="/posts/${post.id.replace(/\.mdx?$/, '')}/">${post.title}</a>
            </h2>
            <p class="text-[var(--color-text-secondary)] mb-3">${post.description}</p>
            <div class="flex items-center justify-between text-sm text-[var(--color-text-muted)]">
              <span>${dateStr}</span>
              <div class="flex gap-2">${tagsHTML}</div>
            </div>
          </article>
        `;
      }).join('');

      resultsContainer.innerHTML = resultsHTML;
    }

    // Event listener for search input
    searchInput.addEventListener('input', (e) => {
      performSearch(e.target.value);
    });

    // Keyboard shortcuts
    searchInput.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') {
        searchInput.value = '';
        performSearch('');
        searchInput.focus();
      }
    });
  </script>
</BaseLayout>
