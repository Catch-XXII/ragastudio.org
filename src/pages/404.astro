---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Page Not Found — ragastudio"
  description="The page you're looking for is no longer available."
>
  <div class="py-12 text-center">
    <h1 class="font-[family-name:var(--font-mono)] text-sm tracking-[3px] uppercase text-[var(--color-text-muted)] font-semibold mb-6">
      This content is no longer available
    </h1>
    
    <p class="text-base md:text-lg text-[var(--color-text-secondary)] leading-relaxed max-w-[500px] mx-auto mb-8">
      The post you're looking for may have been removed or deleted. Browse our latest posts or go back home.
    </p>

    <div class="flex flex-col sm:flex-row gap-4 justify-center mt-10">
      <a
        href="/"
        class="inline-block px-6 py-2 text-sm font-medium text-[var(--color-text)] hover:text-[var(--color-accent)] border border-[var(--color-text-muted)] hover:border-[var(--color-accent)] transition-colors duration-200"
      >
        Back to Home
      </a>
      <a
        href="/posts"
        class="inline-block px-6 py-2 text-sm font-medium text-[var(--color-text)] hover:text-[var(--color-accent)] border border-[var(--color-text-muted)] hover:border-[var(--color-accent)] transition-colors duration-200"
      >
        Browse All Posts
      </a>
    </div>
  </div>
</BaseLayout>
