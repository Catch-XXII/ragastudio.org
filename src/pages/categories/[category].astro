---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PostCard from "../../components/PostCard.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import { getCollection } from "astro:content";
import { getReadingTime } from "../../utils/reading-time";
import { categories, getCategoryById } from "../../config/categories";
import { getEmojiFavicon } from "../../utils/favicon";

export async function getStaticPaths() {
  const posts = await getCollection("posts", ({ data }) => !data.draft);
  return categories.map((category) => ({
    params: { category: category.id },
    props: {
      category: category.id,
      posts: posts
        .filter((post) => post.data.category === category.id)
        .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf()),
    },
  }));
}

const { category, posts } = Astro.props;
const meta = getCategoryById(category);
const favicon = meta ? getEmojiFavicon(meta.emoji) : undefined;
---

<BaseLayout title={`${meta.label} — ragastudio`} description={meta.description} favicon={favicon}>
  <Breadcrumbs items={[{ label: "Categories", href: "/" }, { label: meta.label }]} />
  <header class="mb-8">
    <h1 class="text-4xl font-semibold">
      <span class="mr-3">{meta.icon}</span>{meta.label}
    </h1>
    <p class="text-lg text-[var(--color-text-secondary)] mt-2">{meta.description}</p>
  </header>
  {posts.length > 0 ? (
    posts.map((post) => (
      <PostCard
        title={post.data.title}
        description={post.data.description}
        date={post.data.date}
        tags={post.data.tags}
        slug={post.id}
        readingTime={post.body ? getReadingTime(post.body) : undefined}
      />
    ))
  ) : (
    <p class="text-[var(--color-text-muted)] font-[family-name:var(--font-mono)] text-sm tracking-[1px]">
      No posts in this category yet. Check back soon.
    </p>
  )}
</BaseLayout>
