---
import BaseLayout from "../layouts/BaseLayout.astro";
import PostCard from "../components/PostCard.astro";
import { getCollection } from "astro:content";
import { getReadingTime } from "../utils/reading-time";
import { getEmojiFavicon } from "../utils/favicon";

const posts = (await getCollection("posts", ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 5);

const favicon = getEmojiFavicon('🏠');
---

<BaseLayout
  title="ragastudio"
  description="Personal blog and portfolio by ragastudio"
  favicon={favicon}
>
  <div class="mb-12">
    <p class="text-2xl text-[var(--color-text-secondary)] leading-relaxed">
      Thoughts, experiments, and things worth sharing.
    </p>
  </div>

  {
    posts.length > 0 && (
      <section>
        <h2 class="font-[family-name:var(--font-mono)] text-sm tracking-[3px] uppercase text-[var(--color-text-muted)] font-semibold mb-4">
          Recent Posts
        </h2>
        {posts.map((post) => (
          <PostCard
            title={post.data.title}
            description={post.data.description}
            date={post.data.date}
            tags={post.data.tags}
            slug={post.id}
            readingTime={post.body ? getReadingTime(post.body) : undefined}
          />
        ))}
        <a
          href="/posts"
          class="inline-block mt-6 font-[family-name:var(--font-mono)] text-sm tracking-[2px] uppercase text-[var(--color-text-muted)] hover:text-[var(--color-accent-soft)] transition-colors"
        >
          View all posts →
        </a>
      </section>
    )
  }
</BaseLayout>
